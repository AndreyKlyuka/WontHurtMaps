# Database
POSTGRES_DB=wonthurtmaps
POSTGRES_USER=wonthurt
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql+asyncpg://wonthurt:changeme@localhost:5432/wonthurtmaps

# Telegram API (https://my.telegram.org)
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# Telegram channel display title (dev-only env override; production uses admin panel)
TELEGRAM_CHANNEL_NAME=
TELEGRAM_SESSION_PATH=sessions/telegram.session
TELEGRAM_BOOTSTRAP_LIMIT=500

# Auth
JWT_SECRET=changeme_generate_random_string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:4200

# Worker
PIPELINE_INTERVAL_MINUTES=60
GEOCODING_QUEUE_MAX=500

# Google APIs (https://console.cloud.google.com)
# Gemini: enable "Generative Language API" — https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
LLM_QUEUE_MAX=500
# Google Maps: enable "Maps JavaScript API" + "Geocoding API" in Google Cloud Console
# Used by: backend (geocoding pipeline) + frontend (map display)
# Restrict this key by HTTP referrer in Google Cloud Console
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Route Check (OSRM)
OSRM_URL=https://router.project-osrm.org
